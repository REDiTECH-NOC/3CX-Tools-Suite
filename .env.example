# ── PostgreSQL ──
POSTGRES_USER=wallboard
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=wallboard

# ── Wallboard ──
WALLBOARD_PORT=4200
RELAY_WS_PORT=3100
ENCRYPTION_KEY=changeme_32_char_random_string_here
ENCRYPTION_SALT=changeme_another_random_salt_here
SESSION_SECRET=changeme_session_secret_here

# Admin extensions (comma-separated) — these get ADMIN role on first login
ADMIN_EXTENSIONS=100,101

# PBX connection is configured via the wallboard setup wizard UI, not here.
# The relay agent is installed directly on the PBX — see relay-agent/install.sh.
# The auto-pager is configured via its web UI at port 3001.
